# Dependencies
.git
.gitignore
.Rproj.user
.Rhistory
.RData
*.Rproj

# Documentation
README.md
LICENSE
docs/

# Test data (not needed in production image)
tests/
*.test.R

# Local data (mounted at runtime)
data/input/*
data/output/*

# Keep scenarios directory structure but ignore contents if any
!data/scenarios/.gitkeep

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# CI/CD and development tooling
.github/
.claude/

# Documentation (exclude INSTALL.md which is needed)
*.md
!INSTALL.md

# Scripts not needed in image (except run-shiny.sh)
scripts/*.sh
!scripts/run-shiny.sh

# Security and infrastructure files
security/
tls/
.env
.env.*
!.env.example
Caddyfile
Makefile
