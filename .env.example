# TRISK Docker Environment Variables
# Copy this to .env and customize for your deployment

# --- Caddy reverse proxy ---
# Username for HTTP Basic Auth (default: analyst)
TRISK_USER=analyst
# Password hash (generate with: docker run caddy caddy hash-password --plaintext 'YourPassword')
TRISK_PASS_HASH=

# --- Base image override (for bank Artifactory) ---
# BASE_IMAGE=artifactory.bank.com/approved/r-ver:4.4.1@sha256:...

# --- Shiny settings ---
SHINY_LOG_LEVEL=WARN
# SHINY_HOST=0.0.0.0
# SHINY_PORT=3838

# --- Debug mode (set to true to enable verbose analysis logging in UI) ---
TRISK_DEBUG_LOG=false
