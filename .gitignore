# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# Logs
*.log
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data files (should be mounted, not committed)
data/input/*
data/output/*
# Scenario data is vendored in build context but too large for git (57MB).
# Run `bash scripts/download_scenarios.sh` to fetch it before your first build.
data/scenarios/scenarios.csv
!data/input/.gitkeep
!data/output/.gitkeep
!data/scenarios/.gitkeep

# Build artifacts
*.tar.gz

# Environment files (may contain credentials)
.env
.env.local
.env.production

# TLS certificates (must not be committed)
tls/*.pem
tls/*.key
tls/*.crt
